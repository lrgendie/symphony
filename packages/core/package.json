{
  "name": "@symphony/core",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "description": "symphonyd — Symphony çekirdek daemon'ı: provider katmanı, WS/REST sunucu, sır kasası",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lrgendie/symphony.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./daemon": "./dist/main.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "key:set": "tsx src/secrets/set-key.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.5",
    "@ai-sdk/google": "^4.0.6",
    "@ai-sdk/openai": "^4.0.5",
    "@ai-sdk/openai-compatible": "^3.0.3",
    "@fastify/cors": "^11.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@symphony/shared": "workspace:*",
    "ai": "^7.0.11",
    "better-sqlite3": "^12.11.1",
    "diff": "^9.0.0",
    "execa": "^9.6.1",
    "fastify": "^5.9.0",
    "picomatch": "^4.0.5",
    "pino": "^10.3.1",
    "simple-git": "^3.36.0",
    "tinyglobby": "^0.2.17",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^8.0.0",
    "@types/node": "^26.1.0",
    "@types/picomatch": "^4.0.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4"
  }
}
