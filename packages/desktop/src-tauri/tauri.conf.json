{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Symphony",
  "version": "0.2.0",
  "identifier": "com.symphony.desktop",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @symphony/ui dev",
    "beforeBuildCommand": "pnpm --filter @symphony/ui build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
